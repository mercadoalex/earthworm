# Stage 1: Compile BPF C programs and generate Go bindings
FROM ubuntu:22.04 AS bpf-builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    clang-15 \
    llvm-15 \
    libbpf-dev \
    linux-headers-generic \
    make \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN ln -s /usr/bin/clang-15 /usr/bin/clang && \
    ln -s /usr/bin/llc-15 /usr/bin/llc

WORKDIR /build
COPY src/ebpf/ src/ebpf/
COPY src/agent/gen.go src/agent/gen.go

# Compile BPF programs to .o files
RUN clang -O2 -g -target bpf \
    -I src/ebpf/headers \
    -c src/ebpf/syscall_tracer.c -o src/ebpf/syscall_tracer.o && \
    clang -O2 -g -target bpf \
    -I src/ebpf/headers \
    -c src/ebpf/process_monitor.c -o src/ebpf/process_monitor.o && \
    clang -O2 -g -target bpf \
    -I src/ebpf/headers \
    -c src/ebpf/network_probe.c -o src/ebpf/network_probe.o && \
    clang -O2 -g -target bpf \
    -I src/ebpf/headers \
    -c src/ebpf/heartbeat.c -o src/ebpf/heartbeat.o

# Stage 2: Build Go agent binary
FROM golang:1.21-bookworm AS go-builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    clang-15 \
    llvm-15 \
    libbpf-dev \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/clang-15 /usr/bin/clang

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
COPY --from=bpf-builder /build/src/ebpf/*.o src/ebpf/

# Generate Go bindings via bpf2go
RUN go generate ./src/agent/...

# Build the agent binary
RUN CGO_ENABLED=0 GOOS=linux go build -o /agent ./src/agent/

# Stage 3: Final distroless image
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=go-builder /agent /agent
COPY --from=bpf-builder /build/src/ebpf/*.o /ebpf/

ENTRYPOINT ["/agent"]
